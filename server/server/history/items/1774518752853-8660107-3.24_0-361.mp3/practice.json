      "end": 268.14,
      "words": [
        "The",
        "phrase",
        "'bond",
        "of",
        "trust'",
        "is",
        "a",
        "strong",
        "feeling",
        "of",
        "reliance",
        "and",
        "confidence",
        "between",
        "two",
        "people"
      ]
    },
    {
      "text": "Horses really are special animals.",
      "start": 268.46,
      "end": 270.62,
      "words": [
        "Horses",
        "really",
        "are",
        "special",
        "animals"
      ]
    },
    {
      "text": "They sense human feelings like fear or sadness through breath,",
      "start": 271.02,
      "end": 274.46,
      "words": [
        "They",
        "sense",
        "human",
        "feelings",
        "like",
        "fear",
        "or",
        "sadness",
        "through",
        "breath"
      ]
    },
    {
      "text": "heart rate and movement,",
      "start": 274.7,
      "end": 275.9,
      "words": [
        "heart",
        "rate",
        "and",
        "movement"
      ]
    },
    {
      "text": "and respond with gentleness and calm.",
      "start": 276.06,
      "end": 278.38,
      "words": [
        "and",
        "respond",
        "with",
        "gentleness",
        "and",
        "calm"
      ]
    },
    {
      "text": "This makes them perfect animal therapists.",
      "start": 278.94,
