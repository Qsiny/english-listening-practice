      "end": 350.38,
      "words": [
        "If",
        "you",
        "enjoyed",
        "this",
        "episode"
      ]
    },
    {
      "text": "you'll find a quiz and worksheet to practise the vocabulary on our website: bbclearningenglish.",
      "start": 350.38,
      "end": 356.06,
      "words": [
        "you'll",
        "find",
        "a",
        "quiz",
        "and",
        "worksheet",
        "to",
        "practise",
        "the",
        "vocabulary",
        "on",
        "our",
        "website",
        "bbclearningenglish"
      ]
    },
    {
      "text": "Com.",
      "start": 356.14,
      "end": 356.62,
      "words": [
        "Com"
      ]
    },
